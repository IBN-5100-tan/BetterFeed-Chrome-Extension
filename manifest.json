{
  "manifest_version": 3,
  "name": "BetterFeed",
  "version": "0.1",
  "description": "Freezes YouTube recommendations on a weekly schedule.",
  "key": "",
  "permissions": ["storage", "declarativeNetRequest", "alarms"],
  "host_permissions": ["*://www.youtube.com/*"],
  "action": {
    "default_title": "BetterFeed Settings",
    "default_popup": "popup.html"
  },
  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["*://www.youtube.com/*"],
      "js": ["early.js"],
      "css": ["preload.css"],
      "run_at": "document_start"
    },
    {
      "matches": ["*://www.youtube.com/*"],
      "js": ["shared.js", "content.js"],
      "css": ["home.css", "features.css"]
    }
  ]
}
